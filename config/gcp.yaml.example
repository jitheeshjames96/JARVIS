# config/gcp.yaml — personal GCP dashboard hosting (copy to gcp.yaml)
# Account: jitheeshjames27@gmail.com
# Profile: jarvis-personal
# Project: jarvis-jitheesh-2026 (display name: jarvis)

enabled: false
environment: prod
account: jitheeshjames27@gmail.com
profile: jarvis-personal
project: jarvis-jitheesh-2026
bucket: jarvis-jitheesh-2026
region: asia-south1
public_read: true
cache_control: "max-age=30"

# Sentinel GCP monitor (Cloud Function + hourly scheduler)
sentinel:
  enabled: true
  schedule: "0 * * * *"
  function: sentinel-gcp-monitor
  report_path: ops/sentinel-report.json
